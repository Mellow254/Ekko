{
  "toggletip": {
    "$description": "ekko-toggletip tokens",
    "shared": {
      "background": { "$type": "color", "$value": "{color.surface.overlay}" },
      "text": { "$type": "color", "$value": "{color.text.primary}" },
      "border": { "$type": "color", "$value": "{color.border.default}" },
      "border-width": { "$type": "dimension", "$value": { "value": 1, "unit": "px" } },
      "border-style": { "$value": "solid" },
      "border-radius": { "$type": "dimension", "$value": "{radius.component.md}" },
      "font-family": { "$type": "fontFamily", "$value": "{font.body.family}" },
      "font-weight": { "$type": "fontWeight", "$value": "{font.weight.regular}" },
      "line-height": { "$type": "number", "$value": "{font.leading.normal}" },
      "letter-spacing": { "$type": "dimension", "$value": "{font.tracking.tight}" },
      "gap": {
        "$type": "dimension",
        "$value": "{space.component.sm}",
        "$description": "Gap between items inside the toggletip surface."
      },
      "offset": {
        "$type": "dimension",
        "$value": { "value": 0.5, "unit": "rem" },
        "$description": "Distance between the trigger and the toggletip popover."
      },
      "arrow-size": {
        "$type": "dimension",
        "$value": { "value": 6, "unit": "px" },
        "$description": "Half-length of the toggletip arrow."
      },
      "max-width": {
        "$type": "dimension",
        "$value": { "value": 20, "unit": "rem" },
        "$description": "Maximum width of the toggletip popover."
      },
      "min-width": {
        "$type": "dimension",
        "$value": { "value": 12, "unit": "rem" },
        "$description": "Minimum width of the toggletip popover."
      },
      "shadow-offset-y": { "$type": "dimension", "$value": { "value": 4, "unit": "px" } },
      "shadow-blur": { "$type": "dimension", "$value": { "value": 12, "unit": "px" } },
      "shadow-spread": { "$type": "dimension", "$value": { "value": -2, "unit": "px" } },
      "shadow-color": {
        "$type": "color",
        "$value": "#000000",
        "$description": "Fallback color used inside rgba() for the toggletip shadow."
      },
      "shadow-opacity": { "$type": "number", "$value": 0.18 },
      "transition-duration": { "$type": "duration", "$value": "{duration.fast}" },
      "focus-ring-color": { "$type": "color", "$value": "{focus.ring-color}" },
      "focus-ring-width": { "$type": "dimension", "$value": "{focus.ring-width}" },
      "focus-ring-offset": { "$type": "dimension", "$value": "{focus.ring-offset}" },
      "disabled-opacity": { "$type": "number", "$value": 0.5 },
      "spinner-size": {
        "$type": "dimension",
        "$value": { "value": 0.75, "unit": "rem" },
        "$description": "Width and height of the loading spinner."
      },
      "spinner-border-width": {
        "$type": "dimension",
        "$value": { "value": 2, "unit": "px" }
      },
      "z-index": {
        "$type": "number",
        "$value": 400,
        "$description": "Stacking context for toggletips."
      }
    },
    "trigger": {
      "background": { "$type": "color", "$value": "{color.action.secondary}" },
      "background-hover": { "$type": "color", "$value": "{color.action.secondary-hover}" },
      "background-active": { "$type": "color", "$value": "{color.action.secondary-active}" },
      "text": { "$type": "color", "$value": "{color.action.secondary-text}" },
      "border": { "$type": "color", "$value": "{color.action.secondary-border}" },
      "border-radius": { "$type": "dimension", "$value": "{radius.component.full}" }
    },
    "inverse": {
      "background": { "$type": "color", "$value": "{color.neutral.900}" },
      "text": { "$type": "color", "$value": "{color.text.inverse}" },
      "border": { "$type": "color", "$value": "{color.neutral.900}" }
    },
    "size": {
      "sm": {
        "padding-x": { "$type": "dimension", "$value": "{space.component.sm}" },
        "padding-y": { "$type": "dimension", "$value": "{space.component.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.size.xs}" },
        "trigger-size": { "$type": "dimension", "$value": { "value": 1.25, "unit": "rem" } }
      },
      "md": {
        "padding-x": { "$type": "dimension", "$value": "{space.component.md}" },
        "padding-y": { "$type": "dimension", "$value": "{space.component.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.size.sm}" },
        "trigger-size": { "$type": "dimension", "$value": { "value": 1.5, "unit": "rem" } }
      },
      "lg": {
        "padding-x": { "$type": "dimension", "$value": "{space.component.lg}" },
        "padding-y": { "$type": "dimension", "$value": "{space.component.md}" },
        "font-size": { "$type": "dimension", "$value": "{font.size.md}" },
        "trigger-size": { "$type": "dimension", "$value": { "value": 2, "unit": "rem" } }
      }
    }
  }
}
