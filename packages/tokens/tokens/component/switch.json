{
  "switch": {
    "$description": "ekko-switch tokens",
    "shared": {
      "background": { "$type": "color", "$value": "{color.surface.sunken}" },
      "background-hover": { "$type": "color", "$value": "{color.border.default}" },
      "background-checked": { "$type": "color", "$value": "{color.action.primary}" },
      "background-checked-hover": { "$type": "color", "$value": "{color.action.primary-hover}" },
      "border": { "$type": "color", "$value": "{color.border.default}" },
      "border-checked": { "$type": "color", "$value": "{color.action.primary}" },
      "thumb-color": { "$type": "color", "$value": "{color.surface.default}" },
      "label-text": { "$type": "color", "$value": "{color.text.primary}" },
      "label-text-disabled": { "$type": "color", "$value": "{color.text.disabled}" },
      "border-width": { "$type": "dimension", "$value": { "value": 1, "unit": "px" } },
      "border-style": { "$type": "other", "$value": "solid" },
      "border-radius": { "$type": "dimension", "$value": "{radius.component.full}" },
      "font-family": { "$type": "fontFamily", "$value": "{font.body.family}" },
      "font-weight": { "$type": "fontWeight", "$value": "{font.weight.regular}" },
      "line-height": { "$type": "number", "$value": "{font.leading.tight}" },
      "letter-spacing": {
        "$type": "dimension",
        "$value": "{font.button.tracking}",
        "$description": "Letter-spacing for switch labels."
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.component.sm}",
        "$description": "Gap between the switch track and the label text."
      },
      "transition-duration": { "$type": "duration", "$value": "{duration.fast}" },
      "focus-ring-color": { "$type": "color", "$value": "{focus.ring-color}" },
      "focus-ring-width": { "$type": "dimension", "$value": "{focus.ring-width}" },
      "focus-ring-offset": { "$type": "dimension", "$value": "{focus.ring-offset}" },
      "thumb-shadow-color": {
        "$type": "color",
        "$value": "{color.border.default}",
        "$description": "Subtle shadow colour beneath the thumb for elevation."
      },
      "thumb-shadow-offset": { "$type": "dimension", "$value": { "value": 1, "unit": "px" } },
      "thumb-shadow-blur": { "$type": "dimension", "$value": { "value": 2, "unit": "px" } },
      "disabled-opacity": {
        "$type": "number",
        "$value": 0.5,
        "$description": "Opacity for disabled state."
      }
    },
    "size": {
      "sm": {
        "track-width": { "$type": "dimension", "$value": { "value": 1.75, "unit": "rem" } },
        "track-height": { "$type": "dimension", "$value": { "value": 1, "unit": "rem" } },
        "thumb-size": { "$type": "dimension", "$value": { "value": 0.75, "unit": "rem" } },
        "thumb-offset": { "$type": "dimension", "$value": { "value": 0.125, "unit": "rem" } },
        "thumb-travel": { "$type": "dimension", "$value": { "value": 0.75, "unit": "rem" } },
        "font-size": { "$type": "dimension", "$value": "{font.size.xs}" }
      },
      "md": {
        "track-width": { "$type": "dimension", "$value": { "value": 2.25, "unit": "rem" } },
        "track-height": { "$type": "dimension", "$value": { "value": 1.25, "unit": "rem" } },
        "thumb-size": { "$type": "dimension", "$value": { "value": 1, "unit": "rem" } },
        "thumb-offset": { "$type": "dimension", "$value": { "value": 0.125, "unit": "rem" } },
        "thumb-travel": { "$type": "dimension", "$value": { "value": 1, "unit": "rem" } },
        "font-size": { "$type": "dimension", "$value": "{font.size.sm}" }
      },
      "lg": {
        "track-width": { "$type": "dimension", "$value": { "value": 2.75, "unit": "rem" } },
        "track-height": { "$type": "dimension", "$value": { "value": 1.5, "unit": "rem" } },
        "thumb-size": { "$type": "dimension", "$value": { "value": 1.25, "unit": "rem" } },
        "thumb-offset": { "$type": "dimension", "$value": { "value": 0.125, "unit": "rem" } },
        "thumb-travel": { "$type": "dimension", "$value": { "value": 1.25, "unit": "rem" } },
        "font-size": { "$type": "dimension", "$value": "{font.size.md}" }
      }
    }
  }
}
