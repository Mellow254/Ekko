{
  "button": {
    "$description": "ekko-button tokens",
    "primary": {
      "background": { "$type": "color", "$value": "{color.action.primary}" },
      "background-hover": { "$type": "color", "$value": "{color.action.primary-hover}" },
      "background-active": { "$type": "color", "$value": "{color.action.primary-active}" },
      "background-disabled": { "$type": "color", "$value": "{color.action.primary-disabled}" },
      "text": { "$type": "color", "$value": "{color.action.primary-text}" },
      "text-disabled": { "$type": "color", "$value": "{color.text.disabled}" },
      "border": { "$type": "color", "$value": "{color.action.primary}" },
      "border-disabled": { "$type": "color", "$value": "{color.action.primary-disabled}" }
    },
    "secondary": {
      "background": { "$type": "color", "$value": "{color.action.secondary}" },
      "background-hover": { "$type": "color", "$value": "{color.action.secondary-hover}" },
      "background-active": { "$type": "color", "$value": "{color.action.secondary-active}" },
      "text": { "$type": "color", "$value": "{color.action.secondary-text}" },
      "border": { "$type": "color", "$value": "{color.action.secondary-border}" }
    },
    "ghost": {
      "background": { "$type": "color", "$value": "transparent" },
      "background-hover": { "$type": "color", "$value": "{color.action.ghost-hover}" },
      "background-active": { "$type": "color", "$value": "{color.action.ghost-active}" },
      "text": { "$type": "color", "$value": "{color.action.ghost-text}" },
      "border": { "$type": "color", "$value": "transparent" }
    },
    "danger": {
      "background": { "$type": "color", "$value": "{color.action.danger}" },
      "background-hover": { "$type": "color", "$value": "{color.action.danger-hover}" },
      "background-active": { "$type": "color", "$value": "{color.action.danger-active}" },
      "text": { "$type": "color", "$value": "{color.action.danger-text}" },
      "border": { "$type": "color", "$value": "{color.action.danger}" }
    },
    "shared": {
      "border-radius": { "$type": "dimension", "$value": "{radius.component.md}" },
      "border-width": { "$type": "dimension", "$value": { "value": 1, "unit": "px" } },
      "border-style": {
        "$value": "solid",
        "$description": "Border style for all button variants."
      },
      "font-family": { "$type": "fontFamily", "$value": "{font.body.family}" },
      "font-weight": { "$type": "fontWeight", "$value": "{font.weight.medium}" },
      "line-height": {
        "$type": "number",
        "$value": "{font.button.leading}",
        "$description": "Button label line-height."
      },
      "letter-spacing": {
        "$type": "dimension",
        "$value": "{font.button.tracking}",
        "$description": "Button label letter-spacing."
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.component.sm}",
        "$description": "Gap between label and icon/spinner slots."
      },
      "spinner-size": {
        "$type": "dimension",
        "$value": { "value": 1, "unit": "rem" },
        "$description": "Width and height of the loading spinner."
      },
      "spinner-border-width": {
        "$type": "dimension",
        "$value": { "value": 2, "unit": "px" },
        "$description": "Border width of the loading spinner ring."
      },
      "transition-duration": { "$type": "duration", "$value": "{duration.fast}" },
      "focus-ring-color": { "$type": "color", "$value": "{focus.ring-color}" },
      "focus-ring-width": { "$type": "dimension", "$value": "{focus.ring-width}" },
      "focus-ring-offset": { "$type": "dimension", "$value": "{focus.ring-offset}" }
    },
    "link": {
      "text-underline-offset": {
        "$type": "dimension",
        "$value": { "value": 2, "unit": "px" },
        "$description": "Underline offset for the link variant."
      }
    },
    "pressed": {
      "filter": {
        "$value": "brightness(0.9)",
        "$description": "CSS filter applied to visually indicate pressed/toggled state."
      }
    },
    "loading-label-opacity": {
      "$type": "number",
      "$value": 0.5,
      "$description": "Opacity of button label text during loading state."
    },
    "size": {
      "sm": {
        "padding-x": { "$type": "dimension", "$value": "{space.component.sm}" },
        "padding-y": { "$type": "dimension", "$value": "{space.component.xs}" },
        "font-size": { "$type": "dimension", "$value": "{font.size.sm}" },
        "height": { "$type": "dimension", "$value": { "value": 2, "unit": "rem" } },
        "icon-size": { "$type": "dimension", "$value": { "value": 0.875, "unit": "rem" } }
      },
      "md": {
        "padding-x": { "$type": "dimension", "$value": "{space.component.lg}" },
        "padding-y": { "$type": "dimension", "$value": "{space.component.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.size.sm}" },
        "height": { "$type": "dimension", "$value": { "value": 2.375, "unit": "rem" } },
        "icon-size": { "$type": "dimension", "$value": { "value": 1, "unit": "rem" } }
      },
      "lg": {
        "padding-x": { "$type": "dimension", "$value": "{space.component.xl}" },
        "padding-y": { "$type": "dimension", "$value": "{space.component.md}" },
        "font-size": { "$type": "dimension", "$value": "{font.size.md}" },
        "height": { "$type": "dimension", "$value": { "value": 2.875, "unit": "rem" } },
        "icon-size": { "$type": "dimension", "$value": { "value": 1.125, "unit": "rem" } }
      }
    }
  }
}
