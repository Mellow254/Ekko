{
  "permissions": {
    "allow": [
      "Bash(pnpm build)",
      "Bash(pnpm build:tokens)",
      "Bash(pnpm build:components)",
      "Bash(pnpm test)",
      "Bash(pnpm test:a11y)",
      "Bash(pnpm lint)",
      "Bash(pnpm format)",
      "Bash(pnpm typecheck)",
      "Bash(npx web-test-runner*)",
      "Bash(npx biome*)",
      "Bash(tsc --noEmit)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx @biomejs/biome check --fix --unsafe \"$FILEPATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
